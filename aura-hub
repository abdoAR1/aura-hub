-- Main & AFK Content
local function createSimpleBtn(parent, text, yPos)
    local btn = Instance.new("TextButton", parent)
    btn.BackgroundColor3 = Color3.fromRGB(30, 30, 45); btn.Position = UDim2.new(0, 15, 0, yPos); btn.Size = UDim2.new(0, 250, 0, 35)
    btn.Font = Enum.Font.GothamBold; btn.Text = text .. ": OFF"; btn.TextColor3 = Color3.fromRGB(200, 100, 100)
    Instance.new("UICorner", btn)
    return btn
end

local TokensBtn = createSimpleBtn(PageMain, "Claim Tokens", 10)
local AfkBtn = createSimpleBtn(PageAfk, "Auto-Jump AFK", 10)

-- Logic Functions
local function fireRank(label, idList, currentIdx)
    local id = idList[currentIdx]
    local success, res = pcall(function() return SeasonRemote:InvokeServer(id) end)
    if not success or res == false then
        if currentIdx < #idList then 
            currentIdx = currentIdx + 1
            label.Text = "ID: " .. idList[currentIdx]
            label.TextColor3 = Color3.fromRGB(255, 200, 100)
        end
    else
        label.Text = "ID: " .. id .. " ✔️"
        label.TextColor3 = Color3.fromRGB(100, 255, 150)
    end
    return currentIdx
end

