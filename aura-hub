-- Main Loops
task.spawn(function()
    while task.wait(0.1) do
        if autoTokens then pcall(function() ChallengeRemote:InvokeServer(tokenX); tokenX = tokenX - 1 end) end
    end
end)

task.spawn(function()
    while task.wait(1.5) do
        if autoStyle then styleIndex = fireRank(StyleLabel, validStyleIds, styleIndex) end
        if autoYen then yenIndex = fireRank(YenLabel, validYenIds, yenIndex) end
        if autoAbility then abilityIndex = fireRank(AbilityLabel, validAbilityIds, abilityIndex) end
    end
end)

task.spawn(function()
    while task.wait(300) do
        if autoAfk then
            VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.Space, false, game)
            task.wait(0.1)
            VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.Space, false, game)
        end
    end
end)

