        else
            LoginBtn.Text = "Invalid Key or HWID!"
            TweenService:Create(LoginBtn, TweenInfo.new(0.3), {BackgroundColor3 = Color3.fromRGB(200, 50, 50)}):Play()
            print("Failed Login. Typed Key: " .. tostring(inputKey) .. " | Current HWID: " .. tostring(userHWID))
            task.wait(1.5)
            LoginBtn.Text = "Verify Key"
            TweenService:Create(LoginBtn, TweenInfo.new(0.3), {BackgroundColor3 = Color3.fromRGB(50, 50, 75)}):Play()
        end
    else
        LoginBtn.Text = "Error connecting!"
        TweenService:Create(LoginBtn, TweenInfo.new(0.3), {BackgroundColor3 = Color3.fromRGB(200, 50, 50)}):Play()
        print("Failed to read GitHub file. Are you sure the URL is correct?")
        task.wait(1.5)
        LoginBtn.Text = "Verify Key"
        TweenService:Create(LoginBtn, TweenInfo.new(0.3), {BackgroundColor3 = Color3.fromRGB(50, 50, 75)}):Play()
    end
end)
