-- Smooth Color Transition Function
local function tweenColor(object, targetColor, targetTextColor)
    TweenService:Create(object, TweenInfo.new(0.3), {BackgroundColor3 = targetColor, TextColor3 = targetTextColor}):Play()
end

-- Timer Setup & Management
local function startTimerIfNeeded()
    local inputMinutes = tonumber(TimerInput.Text)
    -- Only start a new timer if one isn't already running
    if inputMinutes and inputMinutes > 0 and timeRemaining <= 0 then
        timeRemaining = inputMinutes * 60
        TimerLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
    end
end

local function formatTime(seconds)
    local mins = math.floor(seconds / 60)
    local secs = seconds % 60
    return string.format("%02d:%02d", mins, secs)
end

local function stopAllFarming()
    autoTokens = false
    autoSpins = false
    tweenColor(TokensBtn, Color3.fromRGB(30, 30, 45), Color3.fromRGB(200, 100, 100))
    TokensBtn.Text = "Claim tokens: OFF"
    tweenColor(SpinsBtn, Color3.fromRGB(30, 30, 45), Color3.fromRGB(200, 100, 100))
    SpinsBtn.Text = "Claim spins: OFF"
    UIStroke.Color = Color3.fromRGB(100, 100, 255)
    TimerLabel.Text = "Farm Complete!"
    TimerLabel.TextColor3 = Color3.fromRGB(100, 255, 150)
    timeRemaining = -1
end

-- Tokens Toggle Logic
TokensBtn.MouseButton1Click:Connect(function()
    autoTokens = not autoTokens
    if autoTokens then
        TokensBtn.Text = "Claim tokens: ON"
        tweenColor(TokensBtn, Color3.fromRGB(100, 255, 150), Color3.fromRGB(20, 50, 20))
        UIStroke.Color = Color3.fromRGB(100, 255, 150)
        startTimerIfNeeded()
    else
        TokensBtn.Text = "Claim tokens: OFF"
        tweenColor(TokensBtn, Color3.fromRGB(30, 30, 45), Color3.fromRGB(200, 100, 100))
        if not autoSpins then UIStroke.Color = Color3.fromRGB(100, 150, 255) end
    end
end)

-- Spins Toggle Logic
SpinsBtn.MouseButton1Click:Connect(function()
    autoSpins = not autoSpins
    if autoSpins then
        SpinsBtn.Text = "Claim spins: ON"
        tweenColor(SpinsBtn, Color3.fromRGB(100, 200, 255), Color3.fromRGB(20, 40, 60))
        UIStroke.Color = Color3.fromRGB(100, 200, 255)
        startTimerIfNeeded()
    else
        SpinsBtn.Text = "Claim spins: OFF"
        tweenColor(SpinsBtn, Color3.fromRGB(30, 30, 45), Color3.fromRGB(200, 100, 100))
        if not autoTokens then UIStroke.Color = Color3.fromRGB(100, 150, 255) end
    end
end)

-- ==========================================
-- BACKGROUND LOOPS
-- ==========================================

-- Master Timer Loop
task.spawn(function()
    while task.wait(1) do
        if (autoTokens or autoSpins) and timeRemaining > 0 then
            timeRemaining = timeRemaining - 1
            TimerLabel.Text = "Timer: " .. formatTime(timeRemaining)
            if timeRemaining <= 0 then
                stopAllFarming()
            end
        elseif (autoTokens or autoSpins) and timeRemaining <= 0 then
            TimerLabel.Text = "Timer: Infinite"
            TimerLabel.TextColor3 = Color3.fromRGB(150, 150, 150)
        end
    end
end)

-- Loop 1: Claim Tokens
task.spawn(function()
    while task.wait(0.1) do
        if autoTokens then
            local currentX = tokenX
            tokenX = tokenX - 1
            
            task.spawn(function()
                pcall(function()
                    ChallengeRemote:InvokeServer(currentX)
                end)
            end)
        end
    end
end)

-- Loop 2: Claim Spins
task.spawn(function()
    while task.wait(1) do
        if autoSpins then
            local targetRank = tonumber(RankInput.Text) or 1 
            
            task.spawn(function()
                pcall(function()
                    SeasonRemote:InvokeServer(targetRank)
                end)
            end)
        end
    end
end)
