-- ID CALCULATOR / SMART ROW UI
local function createSmartRow(parent, yPos, btnText, startID)
    local label = Instance.new("TextLabel", parent)
    label.BackgroundColor3 = Color3.fromRGB(20, 20, 35); label.Position = UDim2.new(0, 15, 0, yPos); label.Size = UDim2.new(0, 75, 0, 35)
    label.Font = Enum.Font.GothamBold; label.Text = "ID: " .. startID; label.TextColor3 = Color3.fromRGB(150, 150, 150)
    Instance.new("UICorner", label)

    local btn = Instance.new("TextButton", parent)
    btn.BackgroundColor3 = Color3.fromRGB(30, 30, 45); btn.Position = UDim2.new(0, 100, 0, yPos); btn.Size = UDim2.new(0, 165, 0, 35)
    btn.Font = Enum.Font.GothamBold; btn.Text = btnText .. ": OFF"; btn.TextColor3 = Color3.fromRGB(200, 100, 100)
    Instance.new("UICorner", btn)
    return label, btn
end

