local function fireSmartRankedReward(label, idArray, currentIndex)
    local currentId = idArray[currentIndex]
    
    local success, result = pcall(function()
        return SeasonRemote:InvokeServer(currentId)
    end)
    
    local failed = false
    if not success then failed = true end
    if result == false or result == nil then failed = true end
    if type(result) == "string" and (string.find(string.lower(result), "error") or string.find(string.lower(result), "fail") or string.find(string.lower(result), "low")) then failed = true end

    if failed then
        if currentIndex < #idArray then
            currentIndex = currentIndex + 1
            label.Text = "ID: " .. idArray[currentIndex]
            label.TextColor3 = Color3.fromRGB(255, 200, 100) -- Yellow (Testing next valid ID)
        else
            label.Text = "ID: " .. currentId .. " (Min)"
            label.TextColor3 = Color3.fromRGB(200, 100, 100) -- Red (Hit bottom valid ID)
        end
    else
        label.Text = "ID: " .. currentId .. " ✔️"
        label.TextColor3 = Color3.fromRGB(100, 255, 150) -- Green (Locked)
    end
    
    return currentIndex
end

