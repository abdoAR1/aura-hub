    AbilityBtn.Text = "Claim Ability Spins: OFF"
    
    tweenColor(LegitStyleBtn, Color3.fromRGB(30, 30, 45), Color3.fromRGB(200, 100, 100))
    LegitStyleBtn.Text = "stylyes underwork: OFF"
    tweenColor(LegitAbilityBtn, Color3.fromRGB(30, 30, 45), Color3.fromRGB(200, 100, 100))
    LegitAbilityBtn.Text = "Auto Ability: OFF"
    SpinnerStatus.Text = "Spinner Status: Idle"
    
    TimerLabel.Text = "Farm Complete!"
    TimerLabel.TextColor3 = Color3.fromRGB(100, 255, 150)
    timeRemaining = -1
end

local function handleToggle(btn, stateVar, name)
    local state = not stateVar
    if state then
        btn.Text = name .. ": ON"
        tweenColor(btn, Color3.fromRGB(100, 255, 150), Color3.fromRGB(20, 50, 20))
        startTimerIfNeeded()
    else
        btn.Text = name .. ": OFF"
        tweenColor(btn, Color3.fromRGB(30, 30, 45), Color3.fromRGB(200, 100, 100))
    end
    return state
end

